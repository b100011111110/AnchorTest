[
  {
    "test_id": "POS_CURRENT_WEATHER_SUCCESS",
    "target": {
      "method": "GET",
      "url": "/v1/weather/current",
      "payload": {
        "lon": -0.12,
        "location": "London",
        "lat": 51.5
      }
    },
    "assertions": [
      {
        "id": "RULE_AUTHCHECK",
        "logic": "present(auth.token)"
      },
      {
        "id": "RULE_SCHEMAVALIDATION",
        "logic": "HAS(location) OR (HAS(lat) AND HAS(lon))"
      },
      {
        "id": "RULE_FIELDCONSTRAINTS",
        "logic": "location.length >= 2 AND location.length <= 100 AND lat >= -90 AND lat <= 90 AND lon >= -180 AND lon <= 180"
      },
      {
        "id": "RULE_CROSSFIELDRULE",
        "logic": "NOT(HAS(lat)) OR HAS(lon)"
      },
      {
        "id": "RULE_LOCATIONEXISTS",
        "logic": "ANY(sql.location_search_result)(result.match = true)"
      }
    ]
  },
  {
    "test_id": "NEG_CURRENT_WEATHER_AUTHCHECK",
    "target": {
      "method": "GET",
      "url": "/v1/weather/current",
      "payload": {
        "lon": -0.12,
        "location": "London",
        "lat": 51.5
      },
      "headers": {
        "X-API-Key": ""
      }
    },
    "assertions": [
      {
        "id": "CHECK_ERROR_CODE",
        "logic": "code == 'AUTH_FAILED'"
      },
      {
        "id": "CHECK_ERROR_MESSAGE",
        "logic": "message == 'Authentication required.'"
      }
    ]
  },
  {
    "test_id": "NEG_CURRENT_WEATHER_SCHEMAVALIDATION",
    "target": {
      "method": "GET",
      "url": "/v1/weather/current",
      "payload": {
        "lon": -0.12,
        "location": "",
        "lat": 51.5
      },
      "headers": {}
    },
    "assertions": [
      {
        "id": "CHECK_ERROR_CODE",
        "logic": "code == 'INVALID_SCHEMA'"
      },
      {
        "id": "CHECK_ERROR_MESSAGE",
